# Backend
DJANGO_SECRET_KEY=your-secret-key-here
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Database
POSTGRES_DB=aviso_db
POSTGRES_USER=aviso_user
POSTGRES_PASSWORD=aviso_password
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Twilio (replace with real credentials in local .env)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_MESSAGING_SERVICE_SID=
TWILIO_DEFAULT_COUNTRY_CODE=+57

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000/api
NEXT_PUBLIC_SITE_NAME=AvisaMe

# Development
NODE_ENV=development
